#!/usr/bin/env bash
# bilibili-autonomous — heartbeat-driven B站 browsing CLI
# Wrapper that finds the right python and forwards args to src/main.py
set -e

SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$SKILL_DIR"

# 优先用 skill 自带的 venv（自包含，可单独移动）
# 退化到 ~/.openclaw/.venv（OpenClaw 共享 venv）
# 退化到系统 python3
if [ -x "$SKILL_DIR/.venv/bin/python3" ]; then
  PY="$SKILL_DIR/.venv/bin/python3"
elif [ -x "$HOME/.openclaw/.venv/bin/python3" ]; then
  PY="$HOME/.openclaw/.venv/bin/python3"
else
  PY="python3"
fi

# Use -m so relative imports work (src/ is a package)
exec "$PY" -m src.main "$@"
