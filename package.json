{
  "name": "bilibili-autonomous",
  "version": "4.0.0",
  "description": "Heartbeat-driven B站 browsing and human-like interaction",
  "main": "src/main.py",
  "bin": {
    "bilibili-autonomous": "./bin/bilibili-autonomous"
  },
  "scripts": {
    "run": "python3 src/main.py run",
    "status": "python3 src/main.py status",
    "dry-run": "python3 src/main.py --dry-run run"
  },
  "openclaw": {
    "type": "executable",
    "entrypoint": "bin/bilibili-autonomous",
    "runtime": "python3"
  },
  "requirements": [
    "bilibili-api==16.0.0",
    "openai>=1.0.0",
    "colorama>=0.4.6"
  ]
}